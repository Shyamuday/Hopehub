{
  "name": "hopehub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/api",
    "apps/user-web",
    "apps/doctor-web",
    "apps/admin-web",
    "apps/operations-web",
    "libs/*",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev --prefix apps/api",
    "dev:user": "npm start --prefix apps/user-web",
    "dev:user:mobile": "npm run build:mobile --prefix apps/user-web",
    "dev:doctor:mobile": "npm run build:mobile --prefix apps/doctor-web",
    "build:user:mobile": "npm run build:mobile --prefix apps/user-web",
    "build:doctor:mobile": "npm run build:mobile --prefix apps/doctor-web",
    "build:operations:mobile": "npm run build:mobile --prefix apps/operations-web",
    "dev:operations:mobile": "npm run build:mobile --prefix apps/operations-web",
    "build:mobile:all": "npm run build:user:mobile && npm run build:doctor:mobile && npm run build:operations:mobile",
    "deploy:configure-urls": "bash deploy/scripts/configure-production-urls.sh",
    "deploy:static": "bash deploy/scripts/build-static.sh",
    "deploy:android": "bash deploy/scripts/build-android-release.sh",
    "deploy:firebase": "bash deploy/scripts/install-google-services.sh",
    "dev:doctor": "npm start --prefix apps/doctor-web",
    "dev:admin": "npm start --prefix apps/admin-web",
    "dev:operations": "npm start --prefix apps/operations-web",
    "dev:hr": "npm run dev:operations",
    "dev:receptionist": "npm run dev:operations",
    "dev:clinic-manager": "npm run dev:operations",
    "dev:accountant": "npm run dev:operations",
    "dev:branch-owner": "npm run dev:operations",
    "dev:coordinator": "npm run dev:operations",
    "dev:callcenter": "npm run dev:operations",
    "dev:marketing": "npm run dev:operations",
    "dev:supplier": "npm run dev:operations",
    "dev:warehouse": "npm run dev:operations",
    "dev:delivery": "npm run dev:operations",
    "dev:diagnostic": "npm run dev:operations",
    "dev:corporate-wellness": "npm run dev:operations",
    "dev:insurance": "npm run dev:operations",
    "dev:store": "npm run dev:operations",
    "dev:store-manager": "npm run dev:operations",
    "dev:partners": "npm run dev:operations",
    "dev:api": "npm run dev --prefix apps/api",
    "build": "npm run build --prefix apps/api && npm run build --prefix apps/user-web",
    "build:all": "npm run build --prefix apps/user-web && npm run build --prefix apps/doctor-web && npm run build --prefix apps/admin-web && npm run build --prefix apps/operations-web",
    "build:user": "npm run build --prefix apps/user-web",
    "build:doctor": "npm run build --prefix apps/doctor-web",
    "build:admin": "npm run build --prefix apps/admin-web",
    "build:operations": "npm run build --prefix apps/operations-web",
    "build:api": "npm run build --prefix apps/api",
    "lint": "eslint . && npm run typecheck",
    "typecheck": "npm run typecheck --prefix apps/api && npm run typecheck --prefix apps/user-web && npm run typecheck --prefix apps/doctor-web && npm run typecheck --prefix apps/admin-web && npm run typecheck --prefix apps/operations-web",
    "test": "npm run test --prefix apps/api && npm run test --prefix apps/user-web -- --watch=false && npm run test --prefix apps/doctor-web -- --watch=false && npm run test --prefix apps/admin-web -- --watch=false && npm run test --prefix apps/operations-web -- --watch=false",
    "format": "prettier --write .",
    "prepare": "husky || true",
    "prisma:generate": "npm run prisma:generate --prefix apps/api",
    "prisma:migrate": "npm run prisma:migrate --prefix apps/api",
    "prisma:deploy": "npm run prisma:deploy --prefix apps/api",
    "prisma:verify": "npm run prisma:verify --prefix apps/api"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.46.4"
  }
}
