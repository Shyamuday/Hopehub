{
  "name": "vitalis-clinic-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/user-web",
    "apps/doctor-web",
    "apps/admin-web",
    "apps/operations-web"
  ],
  "scripts": {
    "dev": "npm run dev --prefix apps/api",
    "dev:user": "npm start --prefix apps/user-web",
    "dev:user:mobile": "npm run build:mobile --prefix apps/user-web",
    "dev:doctor": "npm start --prefix apps/doctor-web",
    "dev:admin": "npm start --prefix apps/operations-web",
    "dev:operations": "npm start --prefix apps/operations-web",
    "dev:hr": "npm run dev:operations",
    "dev:receptionist": "npm run dev:operations",
    "dev:clinic-manager": "npm run dev:operations",
    "dev:accountant": "npm run dev:operations",
    "dev:branch-owner": "npm run dev:operations",
    "dev:coordinator": "npm run dev:operations",
    "dev:callcenter": "npm run dev:operations",
    "dev:marketing": "npm run dev:operations",
    "dev:supplier": "npm run dev:operations",
    "dev:warehouse": "npm run dev:operations",
    "dev:delivery": "npm run dev:operations",
    "dev:diagnostic": "npm run dev:operations",
    "dev:corporate-wellness": "npm run dev:operations",
    "dev:insurance": "npm run dev:operations",
    "dev:store": "npm run dev:operations",
    "dev:store-manager": "npm run dev:operations",
    "dev:partners": "npm run dev:operations",
    "dev:api": "npm run dev --prefix apps/api",
    "build": "npm run build --prefix apps/api && npm run build --prefix apps/user-web",
    "build:all": "npm run build --prefix apps/user-web && npm run build --prefix apps/doctor-web && npm run build --prefix apps/operations-web",
    "build:user": "npm run build --prefix apps/user-web",
    "build:doctor": "npm run build --prefix apps/doctor-web",
    "build:admin": "npm run build --prefix apps/operations-web",
    "build:operations": "npm run build --prefix apps/operations-web",
    "build:api": "npm run build --prefix apps/api",
    "lint": "npm run lint --prefix apps/api",
    "prisma:generate": "npm run prisma:generate --prefix apps/api",
    "prisma:migrate": "npm run prisma:migrate --prefix apps/api",
    "seed": "npm run seed --prefix apps/api"
  }
}
