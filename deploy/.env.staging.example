# Copy to deploy/.env on the STAGING EC2 host. Never commit deploy/.env.

DATABASE_URL="postgresql://hopehub:CHANGE_ME@your-staging-rds.ap-south-1.rds.amazonaws.com:5432/hopehub_clinic_staging?sslmode=require"
JWT_SECRET="staging-only-random-secret"
PORT=4000
NODE_ENV=production
DISABLE_DEV_DEMO=true

API_PUBLIC_URL="https://api.staging.example.com"
WEB_ORIGIN="https://patient.staging.example.com"
DOCTOR_ORIGIN="https://doctor.staging.example.com"
OPERATIONS_ORIGIN="https://ops.staging.example.com"
ADMIN_ORIGIN="https://ops.staging.example.com"

RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

GOOGLE_CLIENT_ID=""

SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@staging.example.com"

NOTIFICATION_CHANNELS="IN_APP,SMS,WHATSAPP,EMAIL"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_SMS_FROM=""
TWILIO_WHATSAPP_FROM=""

DOSE_OVERDUE_SWEEP_ENABLED=true
DOSE_OVERDUE_SWEEP_INTERVAL_MS=300000
DOSE_REMINDER_SWEEP_ENABLED=true
DOSE_REMINDER_WINDOW_MINUTES=30
