# Copy to deploy/.env on the EC2 host. Never commit deploy/.env.

# ── API ───────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://hopehub:CHANGE_ME@your-rds-endpoint.ap-south-1.rds.amazonaws.com:5432/hopehub_clinic?sslmode=require"
JWT_SECRET="generate-a-long-random-secret"
PORT=4000
NODE_ENV=production
DISABLE_DEV_DEMO=true

API_PUBLIC_URL="https://api.hopehub.in"
WEB_ORIGIN="https://hopehub.in"
DOCTOR_ORIGIN="https://doctor.hopehub.in"
OPERATIONS_ORIGIN="https://ops.hopehub.in"
ADMIN_ORIGIN="https://admin.hopehub.in"

# Payments
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Auth
GOOGLE_CLIENT_ID=""

# Email
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@hopehubcare.in"

# Notifications
NOTIFICATION_CHANNELS="IN_APP,SMS,WHATSAPP,EMAIL"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_SMS_FROM=""
TWILIO_WHATSAPP_FROM=""

# Schedulers (defaults are fine for 100–500 patients/day)
DOSE_OVERDUE_SWEEP_ENABLED=true
DOSE_OVERDUE_SWEEP_INTERVAL_MS=300000
DOSE_REMINDER_SWEEP_ENABLED=true
DOSE_REMINDER_WINDOW_MINUTES=30
