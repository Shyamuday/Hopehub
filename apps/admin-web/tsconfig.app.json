{
  "extends": ["./tsconfig.json", "../../tsconfig.base.json"],
  "compilerOptions": {
    "baseUrl": "../..",
    "rootDir": "../..",
    "ignoreDeprecations": "6.0",
    "outDir": "./out-tsc/app",
    "types": []
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.spec.ts"],
  "angularCompilerOptions": {
    "extendedDiagnostics": {
      "checks": {
        "nullishCoalescingNotNullable": "suppress",
        "optionalChainNotNullable": "suppress"
      }
    }
  }
}
