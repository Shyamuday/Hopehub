{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "tslib": ["../../node_modules/tslib"],
      "@vitalis/platform-nav": ["../../libs/platform-nav/src/index.ts"],
      "@vitalis/platform-nav/*": ["../../libs/platform-nav/src/*"],
      "@vitalis/platform-ui": ["../../libs/platform-ui/src/index.ts"],
      "@vitalis/platform-ui/*": ["../../libs/platform-ui/src/*"],
      "@vitalis/app-notifications/*": ["../../libs/platform-ui/src/notification-bell/*"],
      "@vitalis/app-notifications/notification-bell.component": [
        "../../shared/app-notifications/notification-bell.component.ts"
      ],
      "@vitalis/app-notifications/types": ["../../libs/platform-ui/src/notification-bell/types.ts"],
      "@vitalis/role-task-guides": ["../../shared/role-task-guides/index.ts"],
      "@vitalis/role-task-guides/*": ["../../shared/role-task-guides/*"]
    },
    "outDir": "./out-tsc/app",
    "types": []
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.spec.ts"],
  "angularCompilerOptions": {
    "extendedDiagnostics": {
      "checks": {
        "nullishCoalescingNotNullable": "suppress",
        "optionalChainNotNullable": "suppress"
      }
    }
  }
}
