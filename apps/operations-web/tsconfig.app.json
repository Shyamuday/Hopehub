{
  "extends": ["./tsconfig.json", "../../tsconfig.base.json"],
  "compilerOptions": {
    "baseUrl": "../..",
    "rootDir": "../..",
    "ignoreDeprecations": "6.0",
    "outDir": "./out-tsc/app",
    "types": []
  },
  "files": ["src/main.ts"],
  "include": [
    "src/**/*.ts",
    "../admin-web/src/app/features/**/*.ts",
    "../admin-web/src/app/core/**/*.ts",
    "../admin-web/src/app/layout/admin-nav-tabs/**/*.ts"
  ],
  "exclude": [
    "../admin-web/src/app/app.routes.ts",
    "../admin-web/src/app/app.config.ts",
    "../admin-web/src/app/app.ts",
    "../admin-web/src/app/layout/admin-shell/**",
    "../admin-web/src/app/features/auth/**"
  ],
  "angularCompilerOptions": {
    "extendedDiagnostics": {
      "checks": {
        "nullishCoalescingNotNullable": "suppress",
        "optionalChainNotNullable": "suppress"
      }
    }
  }
}
