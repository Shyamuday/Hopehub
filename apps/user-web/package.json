{
  "name": "user-web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:mobile": "ng build && npx cap sync && node scripts/patch-capacitor-permissions.mjs",
    "cap:sync": "ng build && npx cap sync && node scripts/patch-capacitor-permissions.mjs",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "lint": "npm run typecheck",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@10.9.3",
  "dependencies": {
    "@angular/aria": "^22.0.3",
    "@angular/cdk": "^22.0.3",
    "@angular/common": "^22.0.5",
    "@angular/compiler": "^22.0.5",
    "@angular/core": "^22.0.5",
    "@angular/forms": "^22.0.5",
    "@angular/platform-browser": "^22.0.5",
    "@angular/router": "^22.0.5",
    "@capacitor/android": "^6.2.1",
    "@capacitor/camera": "^6.1.3",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/ios": "^6.2.1",
    "@capacitor/push-notifications": "^6.0.5",
    "rxjs": "~7.8.0",
    "socket.io-client": "^4.8.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.5",
    "@angular/cli": "^22.0.5",
    "@angular/compiler-cli": "^22.0.5",
    "prettier": "^3.8.1",
    "typescript": "~6.0.3"
  }
}
