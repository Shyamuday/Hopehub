{
  "name": "clinic-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "npm run typecheck",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:sync": "tsx prisma/sync-migrations.ts",
    "prisma:verify": "tsx scripts/verify-migrations.ts",
    "prisma:push": "prisma db push",
    "repertory:download:oorep": "tsx scripts/download-oorep-sql.ts",
    "repertory:import:oorep": "tsx scripts/import-oorep-sql.ts",
    "verify:doctor-earnings": "tsx scripts/verify-doctor-earnings.ts",
    "verify:finance-period": "tsx scripts/verify-finance-period.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.2.0",
    "@types/express-rate-limit": "^5.1.3",
    "@types/pdfkit": "^0.17.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.10.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.19.1",
    "pg": "^8.20.0",
    "razorpay": "^2.9.6",
    "redis": "^4.7.1",
    "socket.io": "^4.8.1",
    "hopehub": "file:../..",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.3",
    "@types/nodemailer": "^6.4.17",
    "prisma": "^7.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
