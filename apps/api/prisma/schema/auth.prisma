enum Role {
  PATIENT
  DOCTOR
  ADMIN
  HR
  RECEPTIONIST
  CLINIC_MANAGER
  ACCOUNTANT
  SUPPLIER
  WAREHOUSE_MANAGER
  DELIVERY_EXECUTIVE
  DIAGNOSTIC_PARTNER
  BRANCH_OWNER
  PATIENT_COORDINATOR
  CALL_CENTER
  MARKETING
  CORPORATE_WELLNESS
  INSURANCE_PARTNER
}

enum PatientGender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
  PREFER_NOT_TO_SAY
}

enum LifestyleStatus {
  NEVER
  FORMER
  OCCASIONAL
  REGULAR
  PREFER_NOT_TO_SAY
}

enum DietType {
  VEGETARIAN
  NON_VEGETARIAN
  VEGAN
  EGGETARIAN
  MIXED
}

enum ThermalPreference {
  HOT_NATURED
  COLD_NATURED
  MIXED
  NEUTRAL
}

model User {
  id                  String         @id @default(cuid())
  name                String
  email               String?        @unique
  mobile              String?
  passwordHash        String?
  role                Role
  isActive            Boolean        @default(true)
  patientCode         String?        @unique
  profileImageKey     String?
  homeClinicStoreId   String?
  homeClinicStore     Store?         @relation("PatientHomeClinic", fields: [homeClinicStoreId], references: [id])
  allergies           String?
  currentMedications  String?
  chronicConditions   String?
  dateOfBirth         DateTime?
  gender              PatientGender?
  bloodGroup          String?
  alternateMobile     String?
  addressLine1        String?
  addressLine2        String?
  city                String?
  state               String?
  pincode             String?
  country             String?        @default("India")
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?
  occupation          String?
  maritalStatus       MaritalStatus?
  heightCm            Int?
  weightKg            Float?
  pastSurgeries       String?        @db.Text
  familyMedicalHistory String?       @db.Text
  smokingStatus       LifestyleStatus?
  alcoholUse          LifestyleStatus?
  preferredLanguage   String?
  patientNotes        String?        @db.Text
  dietType            DietType?
  foodHabits          String?        @db.Text
  foodCravings        String?        @db.Text
  foodAversions       String?        @db.Text
  appetiteNotes       String?        @db.Text
  thirstNotes         String?        @db.Text
  sleepPattern        String?        @db.Text
  dreamNotes          String?        @db.Text
  thermalPreference   ThermalPreference?
  perspirationNotes   String?        @db.Text
  bowelHabits         String?        @db.Text
  urineHabits         String?        @db.Text
  menstrualHistory    String?        @db.Text
  mentalTemperament   String?        @db.Text
  fearsPhobias        String?        @db.Text
  angerGriefPatterns  String?        @db.Text
  concentrationMemory String?        @db.Text
  socialBehaviour     String?        @db.Text
  stressTriggers      String?        @db.Text
  childhoodIllnesses  String?        @db.Text
  vaccinationHistory  String?        @db.Text
  previousHomeopathicTreatment String? @db.Text
  aggravatingFactors  String?        @db.Text
  relievingFactors    String?        @db.Text
  exerciseHabits      String?        @db.Text
  stimulantHabits     String?        @db.Text
  constitutionalNotes String?        @db.Text
  skinHairNailNotes   String?        @db.Text
  weatherSensitivity  String?        @db.Text
  doctorProfile       Doctor?
  patientConsults     Consultation[] @relation("PatientConsultations")
  doctorConsults      Consultation[] @relation("DoctorConsultations")
  messages            Message[]
  uploadedPrescriptions Prescription[]
  patientPrescriptions Prescription[] @relation("PatientPrescriptions")
  createdPrescriptionOptions PrescriptionOption[] @relation("PrescriptionOptionCreator")
  prescriptionTemplates      PrescriptionTemplate[] @relation("DoctorTemplates")
  doseEvents           MedicineDoseEvent[] @relation("PatientDoseEvents")
  reminderPreference  ReminderPreference?
  auditLogs          AuditLog[]      @relation("AuditActor")
  supportNotesAuthored SupportCaseNote[] @relation("SupportNoteAuthor")
  patientSupportNotes  SupportCaseNote[] @relation("PatientSupportNotes")
  productEvents        ProductEvent[]    @relation("ProductEventActor")
  passwordResetTokens PasswordResetToken[]
  hrProfile              HrProfile?
  receptionistProfile    ReceptionistProfile?
  clinicManagerProfile   ClinicManagerProfile?
  accountantProfile      AccountantProfile?
  supplierProfile        SupplierProfile?
  warehouseManagerProfile WarehouseManagerProfile?
  deliveryExecutiveProfile DeliveryExecutiveProfile?
  diagnosticCenterProfile  DiagnosticCenterProfile?
  branchOwnerProfile       BranchOwnerProfile?
  patientCoordinatorProfile PatientCoordinatorProfile?
  callCenterProfile        CallCenterProfile?
  marketingProfile         MarketingProfile?
  corporateWellnessProfile CorporateWellnessProfile?
  insurancePartnerProfile  InsurancePartnerProfile?
  staffProfile             StaffProfile?
  corporateEnrollments     CorporateEnrollment[] @relation("CorporateEnrollments")
  insuranceClaims          InsuranceClaim[]      @relation("PatientInsuranceClaims")
  assignedDeliveries     MedicineDelivery[] @relation("AssignedDeliveries")
  patientDeliveries      MedicineDelivery[] @relation("PatientDeliveries")
  patientAddresses       PatientAddress[]   @relation("PatientAddresses")
  patientLabReferrals    LabReferral[]      @relation("PatientLabReferrals")
  hrStoreAccess          HrStoreAccess[] @relation("HrUserAccess")
  hrStoreGrants      HrStoreAccess[] @relation("HrAccessGrantor")
  leaveApprovals     LeaveRequest[]  @relation("LeaveApprovals")
  caseAnalyses       CaseAnalysis[]  @relation("DoctorCaseAnalyses")
  patientClinicalMedia ClinicalMedia[] @relation("PatientClinicalMedia")
  clinicalMediaUploads ClinicalMedia[] @relation("ClinicalMediaUploadedBy")
  notificationBroadcasts NotificationBroadcast[] @relation("NotificationBroadcasts")
  inAppNotifications   InAppNotification[]   @relation("UserInAppNotifications")
  createdVacancies     JobVacancy[]           @relation("VacancyCreator")
  chatSessions         ChatSession[]          @relation("UserChatSessions")
  websiteLeads         WebsiteLead[]          @relation("UserWebsiteLeads")
  leadsCalled          WebsiteLead[]          @relation("LeadCalledBy")
  salaryUpdates        EmployeeSalary[]         @relation("SalaryUpdatedBy")
  referredByUserId     String?
  referredByUser       User?                  @relation("PatientReferredBy", fields: [referredByUserId], references: [id], onDelete: SetNull)
  patientsReferred     User[]                 @relation("PatientReferredBy")
  referralCode         PatientReferralCode?
  referralsMade        PatientReferral[]      @relation("ReferralsMade")
  referralReceived     PatientReferral?       @relation("ReferralReceived")
  patientWallet        PatientWallet?
  walletLedger         WalletLedgerEntry[]    @relation("WalletLedgerPatient")
  rewardRedemptions    RewardRedemption[]     @relation("RewardRedemptionPatient")
  blogPostsAuthored    BlogPost[]             @relation("BlogPostAuthor")
  blogComments         BlogComment[]          @relation("BlogCommentAuthor")
  doctorOnlineSession  DoctorOnlineSession?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([mobile])
  @@index([homeClinicStoreId])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actorRole Role?
  action    String
  targetType String
  targetId  String
  summary   String?
  metadata  Json?
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([targetType, targetId])
  @@index([createdAt])
}

model ReminderPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  inApp           Boolean  @default(true)
  sms             Boolean  @default(true)
  whatsapp        Boolean  @default(false)
  push            Boolean  @default(false)
  quietHoursStart String   @default("22:00")
  quietHoursEnd   String   @default("07:00")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}
