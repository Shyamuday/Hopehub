enum RepertorySourceCode {
  REPERTORIUM_PUBLICUM
  OOREP_PUBLICUM
  OOREP_KENT_DE
}

enum CaseAnalysisStatus {
  DRAFT
  FINALIZED
}

enum ClinicalMediaType {
  SKIN
  TONGUE
  NAIL
  HAIR
  SWELLING
  EYE
  EAR
  WOUND
  JOINT
  POSTURE
  DENTAL
  ABDOMEN
  CHEST
  LIMBS
  XRAY
  CT
  MRI
  ULTRASOUND
  ECG
  LAB_REPORT
  PATHOLOGY
  OTHER_IMAGING
  OTHER
}

enum ImagingInterpretationStatus {
  PENDING
  DRAFT
  READY
  DOCTOR_APPROVED
  REJECTED
  FAILED
}

model RepertorySource {
  id          String              @id @default(cuid())
  code        RepertorySourceCode @unique
  name        String
  description String?
  isActive    Boolean             @default(true)
  rubrics     RepertoryRubric[]
  analyses    CaseAnalysis[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model HomeopathicRemedy {
  id               String                  @id @default(cuid())
  oorepRemedyId    Int?                    @unique
  name             String
  abbreviation     String
  normalizedName   String                  @unique
  rubricLinks      RepertoryRubricRemedy[]
  analysisResults  CaseAnalysisResult[]
  selectedAnalyses CaseAnalysis[]          @relation("SelectedRemedy")
  materiaMedica    MateriaMedicaSection[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([abbreviation])
}

model MateriaMedicaSource {
  id            String                 @id @default(cuid())
  oorepMmInfoId Int?                   @unique
  code          String                 @unique
  name          String
  author        String?
  year          Int?
  license       String?
  isActive      Boolean                @default(true)
  sections      MateriaMedicaSection[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
}

model MateriaMedicaSection {
  id             String              @id @default(cuid())
  sourceId       String
  remedyId       String
  oorepSectionId Int?                @unique
  depth          Int                 @default(1)
  heading        String?
  content        String
  sortOrder      Int                 @default(0)
  source         MateriaMedicaSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  remedy         HomeopathicRemedy   @relation(fields: [remedyId], references: [id], onDelete: Cascade)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([remedyId, sourceId, sortOrder])
}

model RepertoryRubric {
  id             String                  @id @default(cuid())
  sourceId       String
  externalId     Int?
  chapter        String
  subchapter     String?
  text           String
  normalizedText String
  parentPath     String?
  source         RepertorySource         @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  remedies       RepertoryRubricRemedy[]
  caseRubrics    CaseAnalysisRubric[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@unique([sourceId, externalId])
  @@index([sourceId, chapter])
  @@index([normalizedText])
}

model RepertoryRubricRemedy {
  id       String            @id @default(cuid())
  rubricId String
  remedyId String
  grade    Int
  rubric   RepertoryRubric   @relation(fields: [rubricId], references: [id], onDelete: Cascade)
  remedy   HomeopathicRemedy @relation(fields: [remedyId], references: [id], onDelete: Cascade)

  @@unique([rubricId, remedyId])
  @@index([remedyId])
}

model CaseAnalysis {
  id               String               @id @default(cuid())
  consultationId   String?
  doctorId         String
  sourceId         String?
  status           CaseAnalysisStatus   @default(DRAFT)
  notes            String?
  caseSheet        Json?
  approachData     Json?
  methodOptionId   String?
  methodRationale           String?
  remedySuggestionSnapshot  Json?
  remedyOverrideRationale   String?
  selectedRemedyId          String?
  methodOption     PrescriptionOption?  @relation("CaseAnalysisMethod", fields: [methodOptionId], references: [id], onDelete: SetNull)
  consultation     Consultation?        @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  doctor           User                 @relation("DoctorCaseAnalyses", fields: [doctorId], references: [id], onDelete: Restrict)
  source           RepertorySource?     @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  selectedRemedy   HomeopathicRemedy?   @relation("SelectedRemedy", fields: [selectedRemedyId], references: [id], onDelete: SetNull)
  rubrics          CaseAnalysisRubric[]
  results          CaseAnalysisResult[]
  prescriptions    Prescription[]
  clinicalMedia         ClinicalMedia[]
  imagingInterpretations ImagingInterpretation[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([consultationId, createdAt])
  @@index([doctorId])
}

model CaseAnalysisRubric {
  id         String          @id @default(cuid())
  analysisId String
  rubricId   String
  weight     Int             @default(1)
  analysis   CaseAnalysis    @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  rubric     RepertoryRubric @relation(fields: [rubricId], references: [id], onDelete: Restrict)

  @@unique([analysisId, rubricId])
}

model CaseAnalysisResult {
  id         String            @id @default(cuid())
  analysisId String
  remedyId   String
  totalScore Int
  coverage   Int
  rank       Int
  analysis   CaseAnalysis      @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  remedy     HomeopathicRemedy @relation(fields: [remedyId], references: [id], onDelete: Cascade)

  @@unique([analysisId, remedyId])
  @@index([analysisId, rank])
}

model ClinicalMedia {
  id               String             @id @default(cuid())
  patientId        String
  caseAnalysisId   String?
  consultationId   String?
  diseaseId        String?
  conditionLabel   String?
  uploadedById     String
  mediaType        ClinicalMediaType
  bodyRegion       String?
  storageKey       String
  mimeType         String
  fileName         String?
  observations     String?
  patientConsent   Boolean            @default(false)
  patient          User               @relation("PatientClinicalMedia", fields: [patientId], references: [id], onDelete: Cascade)
  caseAnalysis     CaseAnalysis?      @relation(fields: [caseAnalysisId], references: [id], onDelete: Cascade)
  consultation     Consultation?      @relation(fields: [consultationId], references: [id], onDelete: SetNull)
  disease          Disease?           @relation(fields: [diseaseId], references: [id], onDelete: SetNull)
  uploadedBy            User                      @relation("ClinicalMediaUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)
  imagingInterpretations ImagingInterpretation[]
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  @@index([patientId, createdAt])
  @@index([caseAnalysisId, createdAt])
}

model ImagingInterpretation {
  id                      String                      @id @default(cuid())
  mediaId                 String
  caseAnalysisId          String?
  status                  ImagingInterpretationStatus @default(DRAFT)
  analysisJobStatus       String                      @default("READY")
  aiProvider              String                      @default("ollama")
  aiModel                 String
  rawAiOutput             String?                     @db.Text
  structuredSnapshot      Json
  patientPreviewSnapshot  Json?
  visibleToPatient        Boolean                     @default(true)
  patientViewedAt         DateTime?
  doctorOverrideRationale String?                     @db.Text
  appliedAt               DateTime?
  media                   ClinicalMedia               @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  caseAnalysis            CaseAnalysis?               @relation(fields: [caseAnalysisId], references: [id], onDelete: Cascade)
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt

  @@index([mediaId, createdAt])
  @@index([caseAnalysisId, createdAt])
}
