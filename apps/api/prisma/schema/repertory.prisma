enum RepertorySourceCode {
  REPERTORIUM_PUBLICUM
  OOREP_PUBLICUM
  OOREP_KENT_DE
}

enum CaseAnalysisStatus {
  DRAFT
  FINALIZED
}

model RepertorySource {
  id          String              @id @default(cuid())
  code        RepertorySourceCode @unique
  name        String
  description String?
  isActive    Boolean             @default(true)
  rubrics     RepertoryRubric[]
  analyses    CaseAnalysis[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model HomeopathicRemedy {
  id               String                  @id @default(cuid())
  oorepRemedyId    Int?                    @unique
  name             String
  abbreviation     String
  normalizedName   String                  @unique
  rubricLinks      RepertoryRubricRemedy[]
  analysisResults  CaseAnalysisResult[]
  selectedAnalyses CaseAnalysis[]          @relation("SelectedRemedy")
  materiaMedica    MateriaMedicaSection[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([abbreviation])
}

model MateriaMedicaSource {
  id            String                 @id @default(cuid())
  oorepMmInfoId Int?                   @unique
  code          String                 @unique
  name          String
  author        String?
  year          Int?
  license       String?
  isActive      Boolean                @default(true)
  sections      MateriaMedicaSection[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
}

model MateriaMedicaSection {
  id             String              @id @default(cuid())
  sourceId       String
  remedyId       String
  oorepSectionId Int?                @unique
  depth          Int                 @default(1)
  heading        String?
  content        String
  sortOrder      Int                 @default(0)
  source         MateriaMedicaSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  remedy         HomeopathicRemedy   @relation(fields: [remedyId], references: [id], onDelete: Cascade)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([remedyId, sourceId, sortOrder])
}

model RepertoryRubric {
  id             String                  @id @default(cuid())
  sourceId       String
  externalId     Int?
  chapter        String
  subchapter     String?
  text           String
  normalizedText String
  parentPath     String?
  source         RepertorySource         @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  remedies       RepertoryRubricRemedy[]
  caseRubrics    CaseAnalysisRubric[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@unique([sourceId, externalId])
  @@index([sourceId, chapter])
  @@index([normalizedText])
}

model RepertoryRubricRemedy {
  id       String            @id @default(cuid())
  rubricId String
  remedyId String
  grade    Int
  rubric   RepertoryRubric   @relation(fields: [rubricId], references: [id], onDelete: Cascade)
  remedy   HomeopathicRemedy @relation(fields: [remedyId], references: [id], onDelete: Cascade)

  @@unique([rubricId, remedyId])
  @@index([remedyId])
}

model CaseAnalysis {
  id               String               @id @default(cuid())
  consultationId   String
  doctorId         String
  sourceId         String?
  status           CaseAnalysisStatus   @default(DRAFT)
  notes            String?
  selectedRemedyId String?
  consultation     Consultation         @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  doctor           User                 @relation("DoctorCaseAnalyses", fields: [doctorId], references: [id], onDelete: Restrict)
  source           RepertorySource?     @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  selectedRemedy   HomeopathicRemedy?   @relation("SelectedRemedy", fields: [selectedRemedyId], references: [id], onDelete: SetNull)
  rubrics          CaseAnalysisRubric[]
  results          CaseAnalysisResult[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([consultationId, createdAt])
  @@index([doctorId])
}

model CaseAnalysisRubric {
  id         String          @id @default(cuid())
  analysisId String
  rubricId   String
  weight     Int             @default(1)
  analysis   CaseAnalysis    @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  rubric     RepertoryRubric @relation(fields: [rubricId], references: [id], onDelete: Restrict)

  @@unique([analysisId, rubricId])
}

model CaseAnalysisResult {
  id         String            @id @default(cuid())
  analysisId String
  remedyId   String
  totalScore Int
  coverage   Int
  rank       Int
  analysis   CaseAnalysis      @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  remedy     HomeopathicRemedy @relation(fields: [remedyId], references: [id], onDelete: Cascade)

  @@unique([analysisId, remedyId])
  @@index([analysisId, rank])
}
