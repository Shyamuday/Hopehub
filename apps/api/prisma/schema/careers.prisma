enum VacancyStatus {
  DRAFT
  OPEN
  CLOSED
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum LocationType {
  REMOTE
  ON_SITE
  HYBRID
}

enum CounsellorApplicationStatus {
  NEW
  REVIEWING
  SHORTLISTED
  REJECTED
  ONBOARDED
}

model JobVacancy {
  id               String        @id @default(cuid())
  title            String
  department       String
  jobType          JobType       @default(FULL_TIME)
  locationType     LocationType  @default(ON_SITE)
  location         String?
  description      String        @db.Text
  requirements     String[]      @default([])
  responsibilities String[]      @default([])
  status           VacancyStatus @default(DRAFT)
  isUrgent         Boolean       @default(false)
  deadline         DateTime?
  salaryRange      String?
  createdById      String?
  createdBy        User?         @relation("VacancyCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([status])
  @@index([department])
  @@index([createdAt])
}

model CounsellorApplication {
  id                  String                       @id @default(cuid())
  status              CounsellorApplicationStatus  @default(NEW)
  fullName            String
  email               String
  phone               String
  city                String
  qualification       String
  specialization      String
  experienceYears     String
  registrationDetails String?
  languages           String
  availability        String
  preferredChannel    String
  resumeLink          String
  portfolioLink       String?
  whyJoin             String                       @db.Text
  source              String                       @default("healing-web")
  entryPage           String?
  adminNote           String?                      @db.Text
  reviewedById        String?
  reviewedBy          User?                        @relation("CounsellorApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt          DateTime?
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt

  @@index([status])
  @@index([email])
  @@index([phone])
  @@index([specialization])
  @@index([createdAt])
}
