model DeliveryExecutiveProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  storeId     String
  employeeId  String?  @unique
  designation String   @default("Delivery Executive")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  store       Store    @relation(fields: [storeId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([storeId])
}

model LeaveRequest {
  id           String       @id @default(cuid())
  employeeType EmployeeType
  doctorId     String?
  storeStaffId String?
  type         LeaveType
  status       LeaveStatus  @default(PENDING)
  startDate    DateTime
  endDate      DateTime
  totalDays    Int
  reason       String
  hrNote       String?
  approvedById String?
  approvedBy   User?        @relation("LeaveApprovals", fields: [approvedById], references: [id])
  doctor       Doctor?      @relation(fields: [doctorId], references: [id])
  storeStaff   StoreStaff?  @relation(fields: [storeStaffId], references: [id])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([employeeType, status])
  @@index([startDate, endDate])
}

model JoiningLetter {
  id           String      @id @default(cuid())
  letterNumber String      @unique
  issuedDate   DateTime    @default(now())
  content      Json
  staffId      String?     @unique
  doctorUserId String?     @unique
  staff        StoreStaff? @relation(fields: [staffId], references: [id])
  doctor       Doctor?     @relation(fields: [doctorUserId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model DoctorSlot {
  id          String   @id @default(cuid())
  doctorId    String
  date        DateTime @db.Date
  startTime   String
  endTime     String
  isBooked    Boolean  @default(false)
  isBlocked   Boolean  @default(false)
  doctor      Doctor   @relation(fields: [doctorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([doctorId, date, startTime])
  @@index([doctorId, date])
  @@index([date, isBooked])
}

/// Admin-managed monthly salary breakdown (Basic, HRA, PF, ESIC, etc.)
model EmployeeSalary {
  id                    String       @id @default(cuid())
  employeeType          EmployeeType
  doctorId              String?      @unique
  storeStaffId          String?      @unique
  doctor                Doctor?      @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  storeStaff            StoreStaff?  @relation(fields: [storeStaffId], references: [id], onDelete: Cascade)

  basicPaise            Int          @default(0)
  hraPaise              Int          @default(0)
  conveyancePaise       Int          @default(0)
  medicalAllowancePaise Int          @default(0)
  specialAllowancePaise Int          @default(0)
  otherAllowancePaise   Int          @default(0)

  employerPfPaise       Int          @default(0)
  employeePfPaise       Int          @default(0)
  employerEsiPaise      Int          @default(0)
  employeeEsiPaise      Int          @default(0)
  professionalTaxPaise  Int          @default(0)
  tdsPaise              Int          @default(0)
  otherDeductionPaise   Int          @default(0)

  grossPaise            Int          @default(0)
  netPaise              Int          @default(0)
  ctcPaise              Int          @default(0)

  effectiveFrom         DateTime     @default(now())
  notes                 String?
  updatedById           String?
  updatedBy             User?        @relation("SalaryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@index([employeeType])
}
