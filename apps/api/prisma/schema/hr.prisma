enum DoctorCompensationModel {
  SALARIED
  CONSULT_ONLY
  HYBRID
}

model Doctor {
  id               String         @id @default(cuid())
  userId           String         @unique
  providerCategory ProviderCategory @default(AYUSH)
  providerType     ProviderType     @default(HOMEOPATH)
  doctorType       HomeopathicDoctorType @default(JUNIOR_DOCTOR)
  specialtyFocus     HomeopathicSpecialtyFocus?
  specialty        String
  specialization   String?
  registrationNo   String?
  isAvailable      Boolean        @default(true)
  isOnline         Boolean        @default(true)
  clinicStoreId    String?
  clinicStore      Store?         @relation("DoctorClinic", fields: [clinicStoreId], references: [id])
  user             User           @relation(fields: [userId], references: [id])

  employeeId       String?        @unique
  designation      String?
  department       String?
  joiningDate      DateTime?
  probationEndDate DateTime?
  salaryPerMonth   Int?
  consultationFee  Int?
  /// How this doctor is paid: fixed salary, per-consultation only, or both.
  compensationModel DoctorCompensationModel @default(HYBRID)
  /// Share of paid consultation revenue (percent). Defaults to 60 when unset in logic.
  consultationSharePercent Int @default(60)
  workShift        WorkShift      @default(FULL_DAY)
  shiftStart       String?
  shiftEnd         String?
  weeklyOffDays    String[]       @default([])
  employeeStatus   EmployeeStatus @default(ACTIVE)
  phone            String?
  address          String?
  emergencyContact String?
  emergencyPhone   String?

  /// Public-facing fields shown on the clinic website
  bio              String?        @db.Text
  showOnWebsite    Boolean        @default(false)
  websiteOrder     Int?
  yearsOfExperience Int?
  focusAreas       String[]       @default([])

  /// Default homeopathic approach / method pre-selected in case taking and prescriptions.
  defaultMethodOptionId String?
  defaultMethodOption   PrescriptionOption? @relation("DoctorDefaultMethod", fields: [defaultMethodOptionId], references: [id], onDelete: SetNull)

  joiningLetter    JoiningLetter?
  leaveRequests    LeaveRequest[]
  slots            DoctorSlot[]
  onlineSession    DoctorOnlineSession?
  salaryStructure  EmployeeSalary?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model HrProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  employeeId  String?  @unique
  designation String   @default("HR Manager")
  department  String   @default("Human Resources")
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HrStoreAccess {
  id          String   @id @default(cuid())
  hrUserId    String
  storeId     String
  grantedById String
  hrUser      User     @relation("HrUserAccess",  fields: [hrUserId],    references: [id], onDelete: Cascade)
  store       Store    @relation(fields: [storeId],     references: [id], onDelete: Cascade)
  grantedBy   User     @relation("HrAccessGrantor", fields: [grantedById], references: [id])
  createdAt   DateTime @default(now())

  @@unique([hrUserId, storeId])
  @@index([hrUserId])
  @@index([storeId])
}

model ReceptionistProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  storeId     String
  employeeId  String?  @unique
  designation String   @default("Receptionist")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
