enum ConsultationStatus {
  PAYMENT_PENDING
  PAID
  ASSIGNED
  IN_PROGRESS
  PRESCRIPTION_UPLOADED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  CREATED
  PAID
  FAILED
}

enum BillingPlanType {
  ONE_TIME_APPOINTMENT
  STARTER_MONTHLY
  CONTINUITY_QUARTERLY
}

enum PublicPageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Disease {
  id                 String         @id @default(cuid())
  name               String         @unique
  slug               String?        @unique
  description        String
  feeInPaise         Int
  intakeQuestions    Json
  isActive           Boolean        @default(true)
  publicCategory     String?
  publicDescription  String?        @db.Text
  publicImageUrl     String?
  seoTitle           String?
  seoDescription     String?        @db.Text
  publicFaq          Json?
  publicPageContent  Json?
  publicPageStatus   PublicPageStatus @default(PUBLISHED)
  publicPagePublishedAt DateTime?
  publicPageReviewedAt  DateTime?
  consultations      Consultation[]
  locationFees       DiseaseLocationFee[]
  clinicalMedia      ClinicalMedia[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([publicCategory])
  @@index([slug])
  @@index([publicPageStatus])
}

/// Per-clinic or online consultation fee override. `locationKey` is `ONLINE` or a store id.
model DiseaseLocationFee {
  id          String   @id @default(cuid())
  diseaseId   String
  locationKey String
  feeInPaise  Int
  disease     Disease  @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([diseaseId, locationKey])
  @@index([locationKey])
}

model Consultation {
  id                    String             @id @default(cuid())
  patientId             String
  diseaseId             String
  assignedDoctorId      String?
  clinicStoreId         String?
  consultationMode      ConsultationMode   @default(CLINIC_QUEUE)
  preferredDoctorUserId String?
  status                ConsultationStatus @default(PAYMENT_PENDING)
  billingPlanCode String?
  pricingSnapshot Json?
  intakeAnswers   Json
  patient         User               @relation("PatientConsultations", fields: [patientId], references: [id])
  disease         Disease            @relation(fields: [diseaseId], references: [id])
  assignedDoctor  User?              @relation("DoctorConsultations", fields: [assignedDoctorId], references: [id])
  clinicStore     Store?             @relation("ConsultationClinic", fields: [clinicStoreId], references: [id])
  payment         Payment?
  messages        Message[]
  prescriptions   Prescription[]
  supportNotes    SupportCaseNote[]
  caseAnalyses    CaseAnalysis[]
  labReferrals    LabReferral[]
  clinicalMedia   ClinicalMedia[]
  websiteLead     WebsiteLead?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model Payment {
  id              String        @id @default(cuid())
  consultationId  String        @unique
  provider        String        @default("razorpay")
  billingPlanCode String?
  providerOrderId String?
  providerPaymentId String?
  grossAmountInPaise Int?
  discountInPaise    Int          @default(0)
  walletRedeemedInPaise Int       @default(0)
  amountInPaise   Int
  lineItems       Json?
  appliedRules    Json?
  status          PaymentStatus @default(CREATED)
  consultation    Consultation  @relation(fields: [consultationId], references: [id])
  rewardRedemptions RewardRedemption[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model BillingPlan {
  id                 String          @id @default(cuid())
  code               String          @unique
  name               String
  description        String?
  planType           BillingPlanType
  priceInPaise       Int
  consultationsLimit Int?
  isActive           Boolean         @default(true)
  sortOrder          Int             @default(0)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model Message {
  id             String       @id @default(cuid())
  consultationId String
  senderId       String
  body           String
  consultation   Consultation @relation(fields: [consultationId], references: [id])
  sender         User         @relation(fields: [senderId], references: [id])
  createdAt      DateTime     @default(now())
}

enum SupportNoteCategory {
  GENERAL
  BILLING
  ADHERENCE
  TECHNICAL
  ESCALATION
}

model SupportCaseNote {
  id             String              @id @default(cuid())
  patientId      String
  consultationId String?
  authorId       String
  category       SupportNoteCategory @default(GENERAL)
  body           String
  patient        User                @relation("PatientSupportNotes", fields: [patientId], references: [id], onDelete: Cascade)
  author         User                @relation("SupportNoteAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  consultation   Consultation?       @relation(fields: [consultationId], references: [id], onDelete: SetNull)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([patientId, createdAt])
  @@index([consultationId])
}
