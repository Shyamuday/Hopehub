enum MedicineDeliveryStatus {
  PENDING
  ASSIGNED
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  CANCELLED
}

enum PatientAddressType {
  HOME
  WORK
  OTHER
}

model PatientAddress {
  id                   String             @id @default(cuid())
  patientId            String
  patient              User               @relation("PatientAddresses", fields: [patientId], references: [id], onDelete: Cascade)
  label                String
  addressType          PatientAddressType @default(HOME)
  recipientName        String
  phone                String
  addressLine1         String
  addressLine2         String?
  landmark             String?
  city                 String
  state                String
  pincode              String
  country              String             @default("India")
  deliveryInstructions String?
  isDefault            Boolean            @default(false)
  isActive             Boolean            @default(true)
  deliveries           MedicineDelivery[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([patientId, isActive])
  @@index([patientId, isDefault])
}

model MedicineDelivery {
  id                   String                 @id @default(cuid())
  deliveryNumber       String                 @unique
  storeId              String
  patientId            String
  prescriptionId       String?
  assignedExecutiveId  String?
  patientAddressId     String?
  status               MedicineDeliveryStatus @default(PENDING)
  deliveryAddress      String
  deliveryPhone        String
  notes                String?
  otpHash              String?
  failureReason        String?
  proofNote            String?
  assignedAt           DateTime?
  pickedUpAt           DateTime?
  deliveredAt          DateTime?
  failedAt             DateTime?
  store                Store                  @relation(fields: [storeId], references: [id])
  patient              User                   @relation("PatientDeliveries", fields: [patientId], references: [id])
  prescription         Prescription?          @relation(fields: [prescriptionId], references: [id])
  assignedExecutive    User?                  @relation("AssignedDeliveries", fields: [assignedExecutiveId], references: [id])
  patientAddress       PatientAddress?        @relation(fields: [patientAddressId], references: [id], onDelete: SetNull)
  lines                MedicineDeliveryLine[]
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  @@index([storeId, status])
  @@index([assignedExecutiveId, status])
  @@index([patientId])
}

model MedicineDeliveryLine {
  id         String           @id @default(cuid())
  deliveryId String
  medicineId String?
  label      String
  qty        Int
  delivery   MedicineDelivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  medicine   StoreMedicine?   @relation(fields: [medicineId], references: [id])

  @@index([deliveryId])
}
