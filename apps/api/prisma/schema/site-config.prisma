/// Generic key-value store for clinic-wide settings editable by admin.
/// Keys are stable identifiers (e.g. "doctorListLimit", "whatsappPhone").
model SiteConfig {
  key       String   @id
  value     String
  label     String?
  updatedAt DateTime @updatedAt

  @@index([key])
}

enum PublicContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model PublicPage {
  id          String              @id @default(cuid())
  slug        String              @unique
  title       String
  subtitle    String?
  summary     String?             @db.Text
  content     Json?
  seo         Json?
  status      PublicContentStatus @default(PUBLISHED)
  sortOrder   Int                 @default(0)
  publishedAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([status])
  @@index([sortOrder])
}
