generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum ConsultationStatus {
  PAYMENT_PENDING
  PAID
  ASSIGNED
  IN_PROGRESS
  PRESCRIPTION_UPLOADED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  CREATED
  PAID
  FAILED
}

enum BillingPlanType {
  ONE_TIME_APPOINTMENT
  STARTER_MONTHLY
  CONTINUITY_QUARTERLY
}

enum PrescriptionStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

enum PrescriptionOptionType {
  METHOD
  DIAGNOSED_DISEASE
}

enum DoseEventStatus {
  PENDING
  TAKEN
  SKIPPED
  MISSED
}

enum ConsultationAttachmentKind {
  PATIENT_REPORT
  DOCTOR_CLINICAL
  OTHER
}

enum ConsultationChannel {
  ONLINE_CHAT
  VIDEO
  PHONE
  IN_CLINIC
}

model User {
  id                  String         @id @default(cuid())
  name                String
  email               String?        @unique
  mobile              String?        @unique
  passwordHash        String?
  role                Role
  isActive            Boolean        @default(true)
  allergies           String?
  currentMedications  String?
  chronicConditions   String?
  doctorProfile       Doctor?
  patientConsults     Consultation[] @relation("PatientConsultations")
  doctorConsults      Consultation[] @relation("DoctorConsultations")
  messages            Message[]
  uploadedPrescriptions Prescription[]
  patientPrescriptions Prescription[] @relation("PatientPrescriptions")
  createdPrescriptionOptions PrescriptionOption[] @relation("PrescriptionOptionCreator")
  prescriptionTemplates      PrescriptionTemplate[] @relation("DoctorTemplates")
  doseEvents           MedicineDoseEvent[] @relation("PatientDoseEvents")
  consultationAttachments ConsultationAttachment[]
  reminderPreference  ReminderPreference?
  /** Patient-owned self-diagnosis worksheets (kingdom, miasm, future tools). */
  selfDiagnosisResults PatientSelfDiagnosisResult[]
  auditLogs          AuditLog[]      @relation("AuditActor")
  passwordResetTokens PasswordResetToken[]
  /** Task-scoped capabilities when role is ADMIN. */
  staffProfile       StaffProfile?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

model StaffProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  isSuperAdmin     Boolean  @default(false)
  permissionCodes  String[] @default([])
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actorRole Role?
  action    String
  targetType String
  targetId  String
  summary   String?
  metadata  Json?
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([targetType, targetId])
  @@index([createdAt])
}

model ReminderPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  inApp           Boolean  @default(true)
  sms             Boolean  @default(true)
  whatsapp        Boolean  @default(false)
  push            Boolean  @default(false)
  quietHoursStart String   @default("22:00")
  quietHoursEnd   String   @default("07:00")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Doctor {
  id             String   @id @default(cuid())
  userId         String   @unique
  specialty      String
  registrationNo String?
  isAvailable    Boolean  @default(true)

  bio                  String?
  qualifications       String?
  homoeopathyMethods   String?
  clinicalFocus        String?
  languagesSpoken      String?
  yearsExperience      Int?
  stateCouncilName     String?
  stateCouncilRegNo    String?

  degreeCertificatePath     String?
  councilRegCertificatePath String?
  otherCredentialPath       String?

  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClinicLocation {
  id            String         @id @default(cuid())
  name          String
  slug          String?        @unique
  addressLine1  String
  addressLine2  String?
  city          String?
  state         String?
  pincode       String?
  phone         String?
  timezone      String         @default("Asia/Kolkata")
  isActive      Boolean        @default(true)
  sortOrder     Int            @default(0)
  consultations Consultation[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([isActive, sortOrder])
}

model Disease {
  id            String         @id @default(cuid())
  name          String         @unique
  description   String
  feeInPaise    Int
  intakeQuestions Json
  isActive      Boolean        @default(true)
  consultations Consultation[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Consultation {
  id              String             @id @default(cuid())
  patientId       String
  diseaseId       String
  assignedDoctorId String?
  locationId      String?
  channel         ConsultationChannel @default(ONLINE_CHAT)
  status          ConsultationStatus @default(PAYMENT_PENDING)
  billingPlanCode String?
  pricingSnapshot Json?
  intakeAnswers   Json
  patient         User               @relation("PatientConsultations", fields: [patientId], references: [id])
  disease         Disease            @relation(fields: [diseaseId], references: [id])
  assignedDoctor  User?              @relation("DoctorConsultations", fields: [assignedDoctorId], references: [id])
  location        ClinicLocation?    @relation(fields: [locationId], references: [id], onDelete: SetNull)
  payment         Payment?
  messages        Message[]
  prescriptions   Prescription[]
  attachments     ConsultationAttachment[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model ConsultationAttachment {
  id             String                     @id @default(cuid())
  consultationId String
  uploadedById   String
  kind           ConsultationAttachmentKind @default(OTHER)
  storagePath    String
  fileName       String?
  mimeType       String?
  caption        String?
  consultation   Consultation               @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  uploadedBy     User                       @relation(fields: [uploadedById], references: [id])
  createdAt      DateTime                   @default(now())

  @@index([consultationId])
}

model Payment {
  id              String        @id @default(cuid())
  consultationId  String        @unique
  provider        String        @default("razorpay")
  billingPlanCode String?
  providerOrderId String?
  providerPaymentId String?
  amountInPaise   Int
  lineItems       Json?
  status          PaymentStatus @default(CREATED)
  consultation    Consultation  @relation(fields: [consultationId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model BillingPlan {
  id                 String          @id @default(cuid())
  code               String          @unique
  name               String
  description        String?
  planType           BillingPlanType
  priceInPaise       Int
  consultationsLimit Int?
  isActive           Boolean         @default(true)
  sortOrder          Int             @default(0)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model Message {
  id             String       @id @default(cuid())
  consultationId String
  senderId       String
  body           String
  consultation   Consultation @relation(fields: [consultationId], references: [id])
  sender         User         @relation(fields: [senderId], references: [id])
  createdAt      DateTime     @default(now())
}

/** Optional patient worksheets (not a medical diagnosis). Keys: kingdom, miasm, … extensible. */
model PatientSelfDiagnosisResult {
  id        String   @id @default(cuid())
  patientId String
  toolKey   String
  answers   Json
  patient   User     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([patientId, toolKey])
  @@index([patientId])
}

model Prescription {
  id             String             @id @default(cuid())
  consultationId String
  uploadedById   String
  patientId      String
  version        Int
  isLatest       Boolean            @default(true)
  methodOptionId String?
  diagnosedDiseaseOptionId String?
  diagnosis      String
  advice         String?
  notes          String
  methodIntakeAnswers Json?
  fileUrl        String?
  followUpDate   DateTime?
  status         PrescriptionStatus @default(DRAFT)
  consultation   Consultation       @relation(fields: [consultationId], references: [id])
  uploadedBy     User               @relation(fields: [uploadedById], references: [id])
  patient        User               @relation("PatientPrescriptions", fields: [patientId], references: [id])
  methodOption   PrescriptionOption? @relation("PrescriptionMethod", fields: [methodOptionId], references: [id])
  diagnosedDiseaseOption PrescriptionOption? @relation("PrescriptionDiagnosedDisease", fields: [diagnosedDiseaseOptionId], references: [id])
  items          PrescriptionItem[]
  doseEvents     MedicineDoseEvent[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([consultationId, version])
  @@index([consultationId, isLatest])
}

model PrescriptionOption {
  id              String                @id @default(cuid())
  type            PrescriptionOptionType
  label           String
  normalizedLabel String
  isSystem        Boolean               @default(false)
  createdById     String?
  createdBy       User?                 @relation("PrescriptionOptionCreator", fields: [createdById], references: [id])
  methodPrescriptions Prescription[]    @relation("PrescriptionMethod")
  diagnosedDiseasePrescriptions Prescription[] @relation("PrescriptionDiagnosedDisease")
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([type, normalizedLabel])
}

model PrescriptionItem {
  id          String       @id @default(cuid())
  prescriptionId String
  medicineName String
  strength    String?
  dose        String?
  frequency   String?
  duration    String?
  instructions String?
  durationDays Int?
  intakeTimes  Json?
  sortOrder   Int          @default(0)
  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  doseEvents   MedicineDoseEvent[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model MedicineDoseEvent {
  id                 String          @id @default(cuid())
  patientId          String
  prescriptionId     String
  prescriptionItemId String
  scheduledFor       DateTime
  status             DoseEventStatus @default(PENDING)
  takenAt            DateTime?
  skippedAt          DateTime?
  note               String?
  patient            User            @relation("PatientDoseEvents", fields: [patientId], references: [id])
  prescription       Prescription    @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  prescriptionItem   PrescriptionItem @relation(fields: [prescriptionItemId], references: [id], onDelete: Cascade)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@unique([prescriptionItemId, scheduledFor])
  @@index([patientId, scheduledFor])
}

model PrescriptionTemplate {
  id          String                   @id @default(cuid())
  doctorId    String
  doctor      User                     @relation("DoctorTemplates", fields: [doctorId], references: [id])
  name        String
  diagnosis   String                   @default("")
  advice      String?
  notes       String                   @default("")
  items       PrescriptionTemplateItem[]
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([doctorId])
}

model PrescriptionTemplateItem {
  id           String               @id @default(cuid())
  templateId   String
  template     PrescriptionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  medicineName String
  strength     String?
  dose         String?
  frequency    String?
  duration     String?
  instructions String?
  sortOrder    Int                  @default(0)
}
