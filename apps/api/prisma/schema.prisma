generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
  HR
}

enum ConsultationStatus {
  PAYMENT_PENDING
  PAID
  ASSIGNED
  IN_PROGRESS
  PRESCRIPTION_UPLOADED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  CREATED
  PAID
  FAILED
}

enum BillingPlanType {
  ONE_TIME_APPOINTMENT
  STARTER_MONTHLY
  CONTINUITY_QUARTERLY
}

enum PrescriptionStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

enum PrescriptionOptionType {
  METHOD
  DIAGNOSED_DISEASE
}

enum DoseEventStatus {
  PENDING
  TAKEN
  SKIPPED
  MISSED
}

model User {
  id                  String         @id @default(cuid())
  name                String
  email               String?        @unique
  mobile              String?        @unique
  passwordHash        String?
  role                Role
  isActive            Boolean        @default(true)
  allergies           String?
  currentMedications  String?
  chronicConditions   String?
  doctorProfile       Doctor?
  patientConsults     Consultation[] @relation("PatientConsultations")
  doctorConsults      Consultation[] @relation("DoctorConsultations")
  messages            Message[]
  uploadedPrescriptions Prescription[]
  patientPrescriptions Prescription[] @relation("PatientPrescriptions")
  createdPrescriptionOptions PrescriptionOption[] @relation("PrescriptionOptionCreator")
  prescriptionTemplates      PrescriptionTemplate[] @relation("DoctorTemplates")
  doseEvents           MedicineDoseEvent[] @relation("PatientDoseEvents")
  reminderPreference  ReminderPreference?
  auditLogs          AuditLog[]      @relation("AuditActor")
  passwordResetTokens PasswordResetToken[]
  hrProfile          HrProfile?
  leaveApprovals     LeaveRequest[]  @relation("LeaveApprovals")
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actorRole Role?
  action    String
  targetType String
  targetId  String
  summary   String?
  metadata  Json?
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([targetType, targetId])
  @@index([createdAt])
}

model ReminderPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  inApp           Boolean  @default(true)
  sms             Boolean  @default(true)
  whatsapp        Boolean  @default(false)
  push            Boolean  @default(false)
  quietHoursStart String   @default("22:00")
  quietHoursEnd   String   @default("07:00")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Doctor {
  id               String         @id @default(cuid())
  userId           String         @unique
  specialty        String
  registrationNo   String?
  isAvailable      Boolean        @default(true)
  user             User           @relation(fields: [userId], references: [id])

  // HR / Onboarding
  employeeId       String?        @unique
  designation      String?
  department       String?
  joiningDate      DateTime?
  probationEndDate DateTime?
  salaryPerMonth   Int?           // in paise
  consultationFee  Int?           // in paise
  workShift        WorkShift      @default(FULL_DAY)
  shiftStart       String?
  shiftEnd         String?
  weeklyOffDays    String[]       @default([])
  employeeStatus   EmployeeStatus @default(ACTIVE)
  phone            String?
  address          String?
  emergencyContact String?
  emergencyPhone   String?

  joiningLetter    JoiningLetter?
  leaveRequests    LeaveRequest[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model HrProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  employeeId  String?  @unique
  designation String   @default("HR Manager")
  department  String   @default("Human Resources")
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum LeaveType {
  CASUAL
  SICK
  EARNED
  UNPAID
  MATERNITY
  PATERNITY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum EmployeeType {
  DOCTOR
  STORE_STAFF
}

model LeaveRequest {
  id           String       @id @default(cuid())
  employeeType EmployeeType
  doctorId     String?
  storeStaffId String?
  type         LeaveType
  status       LeaveStatus  @default(PENDING)
  startDate    DateTime
  endDate      DateTime
  totalDays    Int
  reason       String
  hrNote       String?
  approvedById String?
  approvedBy   User?        @relation("LeaveApprovals", fields: [approvedById], references: [id])
  doctor       Doctor?      @relation(fields: [doctorId], references: [id])
  storeStaff   StoreStaff?  @relation(fields: [storeStaffId], references: [id])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([employeeType, status])
  @@index([startDate, endDate])
}

model Disease {
  id            String         @id @default(cuid())
  name          String         @unique
  description   String
  feeInPaise    Int
  intakeQuestions Json
  isActive      Boolean        @default(true)
  consultations Consultation[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Consultation {
  id              String             @id @default(cuid())
  patientId       String
  diseaseId       String
  assignedDoctorId String?
  status          ConsultationStatus @default(PAYMENT_PENDING)
  billingPlanCode String?
  pricingSnapshot Json?
  intakeAnswers   Json
  patient         User               @relation("PatientConsultations", fields: [patientId], references: [id])
  disease         Disease            @relation(fields: [diseaseId], references: [id])
  assignedDoctor  User?              @relation("DoctorConsultations", fields: [assignedDoctorId], references: [id])
  payment         Payment?
  messages        Message[]
  prescriptions   Prescription[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model Payment {
  id              String        @id @default(cuid())
  consultationId  String        @unique
  provider        String        @default("razorpay")
  billingPlanCode String?
  providerOrderId String?
  providerPaymentId String?
  amountInPaise   Int
  lineItems       Json?
  status          PaymentStatus @default(CREATED)
  consultation    Consultation  @relation(fields: [consultationId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model BillingPlan {
  id                 String          @id @default(cuid())
  code               String          @unique
  name               String
  description        String?
  planType           BillingPlanType
  priceInPaise       Int
  consultationsLimit Int?
  isActive           Boolean         @default(true)
  sortOrder          Int             @default(0)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model Message {
  id             String       @id @default(cuid())
  consultationId String
  senderId       String
  body           String
  consultation   Consultation @relation(fields: [consultationId], references: [id])
  sender         User         @relation(fields: [senderId], references: [id])
  createdAt      DateTime     @default(now())
}

model Prescription {
  id             String             @id @default(cuid())
  consultationId String
  uploadedById   String
  patientId      String
  version        Int
  isLatest       Boolean            @default(true)
  methodOptionId String?
  diagnosedDiseaseOptionId String?
  diagnosis      String
  advice         String?
  notes          String
  fileUrl        String?
  followUpDate   DateTime?
  status         PrescriptionStatus @default(DRAFT)
  consultation   Consultation       @relation(fields: [consultationId], references: [id])
  uploadedBy     User               @relation(fields: [uploadedById], references: [id])
  patient        User               @relation("PatientPrescriptions", fields: [patientId], references: [id])
  methodOption   PrescriptionOption? @relation("PrescriptionMethod", fields: [methodOptionId], references: [id])
  diagnosedDiseaseOption PrescriptionOption? @relation("PrescriptionDiagnosedDisease", fields: [diagnosedDiseaseOptionId], references: [id])
  items          PrescriptionItem[]
  doseEvents     MedicineDoseEvent[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([consultationId, version])
  @@index([consultationId, isLatest])
}

model PrescriptionOption {
  id              String                @id @default(cuid())
  type            PrescriptionOptionType
  label           String
  normalizedLabel String
  isSystem        Boolean               @default(false)
  createdById     String?
  createdBy       User?                 @relation("PrescriptionOptionCreator", fields: [createdById], references: [id])
  methodPrescriptions Prescription[]    @relation("PrescriptionMethod")
  diagnosedDiseasePrescriptions Prescription[] @relation("PrescriptionDiagnosedDisease")
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([type, normalizedLabel])
}

model PrescriptionItem {
  id          String       @id @default(cuid())
  prescriptionId String
  medicineName String
  strength    String?
  dose        String?
  frequency   String?
  duration    String?
  instructions String?
  durationDays Int?
  intakeTimes  Json?
  sortOrder   Int          @default(0)
  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  doseEvents   MedicineDoseEvent[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model MedicineDoseEvent {
  id                 String          @id @default(cuid())
  patientId          String
  prescriptionId     String
  prescriptionItemId String
  scheduledFor       DateTime
  status             DoseEventStatus @default(PENDING)
  takenAt            DateTime?
  skippedAt          DateTime?
  note               String?
  patient            User            @relation("PatientDoseEvents", fields: [patientId], references: [id])
  prescription       Prescription    @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  prescriptionItem   PrescriptionItem @relation(fields: [prescriptionItemId], references: [id], onDelete: Cascade)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@unique([prescriptionItemId, scheduledFor])
  @@index([patientId, scheduledFor])
}

model PrescriptionTemplate {
  id          String                   @id @default(cuid())
  doctorId    String
  doctor      User                     @relation("DoctorTemplates", fields: [doctorId], references: [id])
  name        String
  diagnosis   String                   @default("")
  advice      String?
  notes       String                   @default("")
  items       PrescriptionTemplateItem[]
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([doctorId])
}

model PrescriptionTemplateItem {
  id           String               @id @default(cuid())
  templateId   String
  template     PrescriptionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  medicineName String
  strength     String?
  dose         String?
  frequency    String?
  duration     String?
  instructions String?
  sortOrder    Int                  @default(0)
}

// ─── HR / Employee Management ─────────────────────────────────────────────────

enum WorkShift {
  MORNING
  AFTERNOON
  EVENING
  NIGHT
  FULL_DAY
  CUSTOM
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  RESIGNED
  TERMINATED
}

model JoiningLetter {
  id           String      @id @default(cuid())
  letterNumber String      @unique
  issuedDate   DateTime    @default(now())
  content      Json
  staffId      String?     @unique
  doctorUserId String?     @unique
  staff        StoreStaff? @relation(fields: [staffId], references: [id])
  doctor       Doctor?     @relation(fields: [doctorUserId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

// ─── Medicine Store Management ───────────────────────────────────────────────

enum StoreRole {
  MANAGER
  STAFF
}

enum StockMovementType {
  PURCHASE_IN
  SALE_OUT
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  TRANSFER_IN
  TRANSFER_OUT
  EXPIRED_REMOVAL
}

enum StockStatus {
  ACTIVE
  LOW_STOCK
  OUT_OF_STOCK
  DISCONTINUED
}

model Store {
  id        String          @id @default(cuid())
  name      String
  code      String          @unique
  address   String?
  phone     String?
  isActive  Boolean         @default(true)
  racks     StoreRack[]
  stocks    MedicineStock[]
  staff     StoreStaff[]
  movements StockMovement[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model StoreStaff {
  id               String         @id @default(cuid())
  name             String
  staffCode        String         @unique
  employeeId       String?        @unique
  pinHash          String
  role             StoreRole      @default(STAFF)
  storeId          String
  store            Store          @relation(fields: [storeId], references: [id])
  isActive         Boolean        @default(true)
  employeeStatus   EmployeeStatus @default(ACTIVE)

  // HR / Onboarding
  phone            String?
  email            String?
  address          String?
  designation      String?
  department       String?
  joiningDate      DateTime?
  probationEndDate DateTime?
  salaryPerMonth   Int?           // in paise
  workShift        WorkShift      @default(FULL_DAY)
  shiftStart       String?        // "09:00"
  shiftEnd         String?        // "18:00"
  weeklyOffDays    String[]       @default([])
  emergencyContact String?
  emergencyPhone   String?

  movements        StockMovement[]
  joiningLetter    JoiningLetter?
  leaveRequests    LeaveRequest[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model StoreRack {
  id           String          @id @default(cuid())
  storeId      String
  store        Store           @relation(fields: [storeId], references: [id])
  rackCode     String
  shelfCode    String
  boxCode      String
  label        String?
  potencyColor String?
  stocks       MedicineStock[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([storeId, rackCode, shelfCode, boxCode])
  @@index([storeId])
}

model StoreMedicine {
  id            String          @id @default(cuid())
  name          String
  shortName     String?
  alternateName String?
  manufacturer  String?
  potency       String
  category      String?
  description   String?
  minStockLevel Int             @default(10)
  isActive      Boolean         @default(true)
  qrCode        String?         @unique
  barcode       String?         @unique
  stocks        MedicineStock[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([name])
  @@index([potency])
}

model MedicineStock {
  id          String          @id @default(cuid())
  medicineId  String
  storeId     String
  rackId      String?
  currentQty  Int             @default(0)
  status      StockStatus     @default(ACTIVE)
  medicine    StoreMedicine   @relation(fields: [medicineId], references: [id])
  store       Store           @relation(fields: [storeId], references: [id])
  rack        StoreRack?      @relation(fields: [rackId], references: [id])
  batches     StockBatch[]
  movements   StockMovement[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([medicineId, storeId])
  @@index([storeId, status])
}

model StockBatch {
  id                   String        @id @default(cuid())
  stockId              String
  batchNumber          String
  manufacturer         String?
  purchaseDate         DateTime      @default(now())
  expiryDate           DateTime
  purchasePricePerUnit Int
  sellingPricePerUnit  Int
  qty                  Int
  stock                MedicineStock @relation(fields: [stockId], references: [id])
  movements            StockMovement[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([expiryDate])
  @@index([stockId])
}

model StockMovement {
  id        String            @id @default(cuid())
  stockId   String
  storeId   String
  batchId   String?
  staffId   String?
  type      StockMovementType
  qty       Int
  note      String?
  stock     MedicineStock     @relation(fields: [stockId], references: [id])
  store     Store             @relation(fields: [storeId], references: [id])
  batch     StockBatch?       @relation(fields: [batchId], references: [id])
  staff     StoreStaff?       @relation(fields: [staffId], references: [id])
  createdAt DateTime          @default(now())

  @@index([storeId, createdAt])
  @@index([stockId])
}
