DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hopehub_clinic?schema=public"
JWT_SECRET="change-this-before-production"
NODE_ENV="development"
PORT=4000
API_PUBLIC_URL="http://localhost:4000"
API_URL="http://localhost:4000"
WEB_ORIGIN="http://localhost:4203"
CORS_ORIGINS="http://localhost:4203,http://localhost:4204,http://localhost:4200,http://127.0.0.1:4203,http://127.0.0.1:4204,http://127.0.0.1:4200"
ADMIN_ORIGIN="http://localhost:4201"
DOCTOR_ORIGIN="http://localhost:4202"
OPERATIONS_ORIGIN="http://localhost:5800"
# Redis (optional — OTP store falls back to in-memory when unset)
REDIS_URL="redis://localhost:6379"
# Patient app download links (optional — QR /go/app uses these when set)
PATIENT_APP_ANDROID_URL=""
PATIENT_APP_IOS_URL=""
PATIENT_APP_NAME="HopeHub Patient"
PATIENT_APP_PACKAGE_ID="com.hopehubclinic.patient"
DEV_OTP="123456"
DISABLE_DEV_DEMO="false"
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
GOOGLE_CLIENT_ID=""
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@hopehubcare.in"
DOSE_OVERDUE_SWEEP_ENABLED="true"
DOSE_OVERDUE_SWEEP_INTERVAL_MS="300000"
DOSE_REMINDER_SWEEP_ENABLED="true"
DOSE_REMINDER_WINDOW_MINUTES="30"
NOTIFICATION_CHANNELS="IN_APP,SMS,WHATSAPP,EMAIL,PUSH"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_SMS_FROM=""
TWILIO_WHATSAPP_FROM=""
# OOREP GPL repertory import (optional — see apps/api/data/oorep/README.md)
OOREP_SQL_PATH="data/oorep/oorep.sql"
# Live OOREP proxy (optional — used when local repertory data is unavailable)
OOREP_BASE_URL="https://www.oorep.com"
OOREP_TIMEOUT_MS="15000"
# WebRTC TURN server (optional — falls back to public STUN when unset)
TURN_URL=""
TURN_USERNAME=""
TURN_CREDENTIAL=""
# Local vision AI for clinical image analysis (optional — requires Ollama running locally)
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_VISION_MODEL="qwen2.5-vl:7b"
OLLAMA_VISION_TIMEOUT_MS="120000"
