{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "paths": {
      "@hopehub/homeopathy-approaches": ["../../libs/homeopathy-approaches/src/index.ts"],
      "@hopehub/homeopathy-approaches/*": ["../../libs/homeopathy-approaches/src/*"]
    }
  },
  "include": ["src/**/*.ts", "prisma/**/*.ts"]
}
